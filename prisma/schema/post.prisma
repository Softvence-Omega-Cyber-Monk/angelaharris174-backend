model Post {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  url       String
  caption   String?
  likes     Int     @default(0)
  comments  Int     @default(0)
  viewCount Int     @default(0)

  likesList    Like[]
  commentsList Comment[]
  views        PostView[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
