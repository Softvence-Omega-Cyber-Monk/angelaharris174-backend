model Post {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  url      String
  caption  String?
  likes    Int     @default(0)
  comments Int     @default(0)
  views    Float   @default(0)

  likesList    Like[]
  commentsList Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
